//@version=5
indicator("Claude - Trend-Following — EMA + MACD", overlay=true, shorttitle="TF Signals", max_lines_count=500)

// ─── Paramètres EMA / MACD ─────────────────────────────────────────────────────
emaFastLen  = input.int(9,   title="EMA Rapide",     minval=1, group="Indicateurs")
emaSlowLen  = input.int(21,  title="EMA Lente",      minval=1, group="Indicateurs")
emaRSlowLen = input.int(200, title="EMA très Lente", minval=1, group="Indicateurs")
macdFast    = input.int(12,  title="MACD Fast",      minval=1, group="Indicateurs")
macdSlow    = input.int(26,  title="MACD Slow",      minval=1, group="Indicateurs")
macdSignal  = input.int(9,   title="MACD Signal",    minval=1, group="Indicateurs")
showEMAs    = input.bool(true, title="Afficher les EMAs", group="Indicateurs")

// ─── Paramètres S/R ────────────────────────────────────────────────────────────
showSR     = input.bool(true,  title="Afficher les niveaux",   group="Support / Résistance")
pivLeft    = input.int(10,     title="Pivot – barres gauche",  minval=2,    maxval=100,  group="Support / Résistance")
pivRight   = input.int(10,     title="Pivot – barres droite",  minval=2,    maxval=100,  group="Support / Résistance")
srZonePct  = input.float(0.3,  title="Tolérance de zone (%)", minval=0.05, maxval=3.0,  step=0.05, group="Support / Résistance")
srMaxLvl   = input.int(20,     title="Niveaux max affichés",  minval=5,    maxval=50,   group="Support / Résistance")
srAgeLimit = input.int(300,    title="Âge max (bougies)",     minval=50,   maxval=2000, group="Support / Résistance")

// ─── Calculs EMA / MACD ────────────────────────────────────────────────────────
emaFast  = ta.ema(close,  emaFastLen)
emaSlow  = ta.ema(close,  emaSlowLen)
emaRSlow = ta.ema(close, emaRSlowLen)
[macdLine, signalLine, _] = ta.macd(close, macdFast, macdSlow, macdSignal)

emaCrossUp   = ta.crossover(emaFast, emaSlow)
emaCrossDown = ta.crossunder(emaFast, emaSlow)
macdBullish  = macdLine > signalLine
macdBearish  = macdLine < signalLine
buySignal    = emaCrossUp   and macdBullish
sellSignal   = emaCrossDown and macdBearish

// ─── Tracé EMAs ────────────────────────────────────────────────────────────────
plot(showEMAs ?  emaFast : na, title="EMA 9",   color=color.new(color.teal,   20), linewidth=1)
plot(showEMAs ?  emaSlow : na, title="EMA 21",  color=color.new(color.orange,  20), linewidth=1)
plot(showEMAs ? emaRSlow : na, title="EMA 200", color=color.new(color.white,   20), linewidth=2)

// ─── Signaux ───────────────────────────────────────────────────────────────────
plotshape(buySignal,  title="BUY",  style=shape.triangledown, location=location.abovebar,
          color=color.new(color.teal, 0), textcolor=color.white, text="BUY",  size=size.normal)
plotshape(sellSignal, title="SELL", style=shape.triangleup,   location=location.belowbar,
          color=color.new(color.red,  0), textcolor=color.white, text="SELL", size=size.normal)

// ─── Fond position longue ──────────────────────────────────────────────────────
var bool inLong = false
if buySignal
    inLong := true
if sellSignal
    inLong := false

// ─── Alertes ───────────────────────────────────────────────────────────────────
alertcondition(buySignal,  title="BUY",  message="📈 BUY : EMA9 croise EMA21 à la hausse & MACD > Signal")
alertcondition(sellSignal, title="SELL", message="📉 SELL : EMA9 croise EMA21 à la baisse & MACD < Signal")

// ════════════════════════════════════════════════════════════════════════════════
// SUPPORT / RÉSISTANCE DYNAMIQUE
// ════════════════════════════════════════════════════════════════════════════════
//
//  Force d'un niveau = f(touches, âge)
//  ┌─────────────┬──────────────────────────────────────────────────────────┐
//  │ Épaisseur   │ 1 touche → 1px │ 2 → 2px │ 3 → 3px │ 4+ → 4px          │
//  │ Opacité     │ Récent + fort  = très visible                            │
//  │             │ Vieux  + faible = très transparent                       │
//  │ Style       │ Solide si âge < 50% limite │ Pointillé au-delà           │
//  └─────────────┴──────────────────────────────────────────────────────────┘

var float[] lvlPrice   = array.new_float(0)
var int[]   lvlTouches = array.new_int(0)
var int[]   lvlBar     = array.new_int(0)
var bool[]  lvlIsRes   = array.new_bool(0)
var line[]  lvlLines   = array.new_line(0)

// Épaisseur basée sur le nombre de touches
f_width(t) =>
    t >= 5 ? 4 : t >= 4 ? 3 : t >= 3 ? 2 : 1

// Opacité : âge augmente la transparence, touches la diminuent
// alpha TV : 0 = opaque, 100 = invisible
f_color(isRes, age, touches) =>
    ageAlpha   = int(age * 65.0 / srAgeLimit)       // 0 → 65 selon âge
    touchAlpha = math.min(50, (touches - 1) * 18)   // 0, 18, 36, 50 selon touches
    alpha      = math.max(0, math.min(88, 15 + ageAlpha - touchAlpha))
    isRes ? color.new(#FF5555, alpha) : color.new(#22CCEE, alpha)

// Style : plein si récent, pointillé si vieux
f_style(age) =>
    age > srAgeLimit / 2 ? line.style_dashed : line.style_solid

// Recherche un niveau existant dans la zone de tolérance, retourne son index ou -1
f_findLevel(price) =>
    res = -1
    sz  = array.size(lvlPrice)
    if sz > 0
        for i = 0 to sz - 1
            if math.abs(array.get(lvlPrice, i) - price) / price * 100 <= srZonePct
                res := i
                break
    res

// Supprime le niveau à l'index i (ligne + données)
f_delete(i) =>
    line.delete(array.get(lvlLines, i))
    array.remove(lvlPrice,   i)
    array.remove(lvlTouches, i)
    array.remove(lvlBar,     i)
    array.remove(lvlIsRes,   i)
    array.remove(lvlLines,   i)

// Ajoute un niveau ou incrémente un niveau existant proche
f_addOrUpdate(price, isRes) =>
    idx = f_findLevel(price)
    if idx >= 0
        // Niveau existant : +1 touche, mise à jour visuelle
        newT = array.get(lvlTouches, idx) + 1
        array.set(lvlTouches, idx, newT)
        age = bar_index - array.get(lvlBar, idx)
        l   = array.get(lvlLines, idx)
        line.set_width(l, f_width(newT))
        line.set_color(l, f_color(array.get(lvlIsRes, idx), age, newT))
    else
        // Quota atteint → supprime le plus ancien
        if array.size(lvlPrice) >= srMaxLvl
            oldestIdx = 0
            oldestBar = array.get(lvlBar, 0)
            sz = array.size(lvlBar)
            if sz > 1
                for i = 1 to sz - 1
                    b = array.get(lvlBar, i)
                    if b < oldestBar
                        oldestBar := b
                        oldestIdx := i
            f_delete(oldestIdx)
        // Crée la nouvelle ligne au point de pivot (décalé de pivRight)
        startBar = bar_index - pivRight
        col      = isRes ? color.new(#FF5555, 15) : color.new(#22CCEE, 15)
        newLine  = line.new(startBar, price, bar_index, price, extend=extend.right, color=col, width=1, style=line.style_solid)
        array.push(lvlPrice,   price)
        array.push(lvlTouches, 1)
        array.push(lvlBar,     startBar)
        array.push(lvlIsRes,   isRes)
        array.push(lvlLines,   newLine)

// ─── Détection pivots et gestion des niveaux ──────────────────────────────────
pivH = ta.pivothigh(high, pivLeft, pivRight)
pivL = ta.pivotlow(low,  pivLeft, pivRight)

if showSR
    if not na(pivH)
        f_addOrUpdate(pivH, true)
    if not na(pivL)
        f_addOrUpdate(pivL, false)

    // Chaque barre : nettoyage des expirés + mise à jour style/couleur selon âge
    sz = array.size(lvlPrice)
    if sz > 0
        i = sz - 1
        while i >= 0
            age = bar_index - array.get(lvlBar, i)
            if age > srAgeLimit
                f_delete(i)
            else
                l = array.get(lvlLines, i)
                line.set_style(l, f_style(age))
                line.set_color(l, f_color(array.get(lvlIsRes, i), age, array.get(lvlTouches, i)))
            i -= 1
